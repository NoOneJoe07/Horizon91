# =============================================================================
# Citadelle Jiu-Jitsu — Variables d'environnement
# =============================================================================
# Copier ce fichier en .env.local pour le développement local.
# JAMAIS committer .env.local — il est dans .gitignore.
# =============================================================================

# --- Base de données (PostgreSQL) ---------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://citadelle:changeme@localhost:5432/citadelle_dev?schema=public"

# --- Authentification (JWT) ---------------------------------------------------
# Générer une clé secrète aléatoire forte :
#   openssl rand -base64 64
JWT_SECRET="REMPLACE_PAR_UNE_CLE_DE_64_OCTETS_MINIMUM_GENEREE_ALEATOIREMENT"
# Durée de vie du token (en secondes). 7j = 604800.
JWT_EXPIRES_IN="604800"

# --- Stripe (paiement) --------------------------------------------------------
# Clés de test : commencent par sk_test_ / pk_test_
# Clés de prod : commencent par sk_live_ / pk_live_ (à ne JAMAIS exposer côté client)
STRIPE_SECRET_KEY="sk_test_REMPLACE"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_REMPLACE"
STRIPE_WEBHOOK_SECRET="whsec_REMPLACE"

# --- Email (notifications) ----------------------------------------------------
# Choisir un provider : Resend (simple) OU Nodemailer/SMTP
RESEND_API_KEY="re_REMPLACE"
EMAIL_FROM="noreply@citadellejiujitsu.ca"
EMAIL_OWNER="proprietaire@citadellejiujitsu.ca"

# --- Application --------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"

# --- Compte admin par défaut (seed initial uniquement) ------------------------
# Utilisé par prisma/seed.ts pour créer le 1er compte admin.
# À CHANGER IMPÉRATIVEMENT après la 1ère connexion en prod.
SEED_ADMIN_EMAIL="admin@citadellejiujitsu.ca"
SEED_ADMIN_PASSWORD="ChangeMeImmediately!2026"
